{
	"name": "zulinx86-code-trail",
	"displayName": "Code Trail",
	"description": "Mark and link code reading notes as Markdown files with YAML frontmatter.",
	"version": "0.0.7",
	"publisher": "zulinx86",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/zulinx86/code-trail-vscode-extension.git"
	},
	"engines": {
		"vscode": "^1.105.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "codeTrail.markCode",
				"title": "Code Trail: Mark Code"
			},
			{
				"command": "codeTrail.linkMark",
				"title": "Code Trail: Link Mark"
			},
			{
				"command": "codeTrail.showGraph",
				"title": "Code Trail: Show Graph"
			}
		],
		"keybindings": [
			{
				"command": "codeTrail.markCode",
				"key": "ctrl+shift+m",
				"when": "editorTextFocus"
			},
			{
				"command": "codeTrail.linkMark",
				"key": "ctrl+shift+l",
				"when": "editorTextFocus"
			},
			{
				"command": "codeTrail.showGraph",
				"key": "ctrl+shift+g"
			}
		]
	},
	"scripts": {
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"fmt": "prettier --write .",
		"fmt:check": "prettier --check .",
		"compile": "npm run check-types && npm run lint && npm run fmt && node esbuild.js",
		"package": "npm run check-types && npm run lint && npm run fmt && node esbuild.js --production",
		"vscode:prepublish": "npm run package",
		"compile-tests": "tsc -p . --outDir out",
		"pretest": "rm -rf out && npm run compile-tests && npm run compile",
		"test": "vscode-test --coverage --coverage-reporter html",
		"install-local": "npx vsce package && code --install-extension zulinx86-code-trail-0.0.7.vsix",
		"publish": "npx vsce publish",
		"watch": "npm-run-all -p watch:*",
		"watch:esbuild": "node esbuild.js --watch",
		"watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
		"watch-tests": "tsc -p . -w --outDir out",
		"gif": "ffmpeg -i demo.mov -vf \"fps=10,scale=800:-1:flags=lanczos,split[s0][s1];[s0]palettegen=max_colors=64:stats_mode=full[p];[s1][p]paletteuse=dither=bayer:bayer_scale=3\" demo.gif"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"@types/vscode": "^1.105.0",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.3",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"dependencies": {
		"@dagrejs/dagre": "^3.0.0",
		"vis-data": "^8.0.3",
		"vis-network": "^10.0.2"
	}
}
